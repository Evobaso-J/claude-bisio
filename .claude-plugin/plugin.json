{
  "name": "evobaso",
  "description": "Prints a Claudio Bisio ASCII-art banner on every Claude Code session start. Pun on claude.",
  "author": {
    "name": "Evobaso-J",
    "url": "https://github.com/Evobaso-J"
  },
  "homepage": "https://github.com/Evobaso-J/claude-bisio",
  "repository": "https://github.com/Evobaso-J/claude-bisio",
  "license": "MIT",
  "keywords": ["banner", "ascii-art", "fun", "italian"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/banner.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
